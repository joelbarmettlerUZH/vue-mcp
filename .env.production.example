# External APIs
JINA_API_KEY=
GEMINI_API_KEY=

# Qdrant (local container, no auth)
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=vue_docs

# PostgreSQL
DATABASE_URL=postgresql+psycopg://vue_mcp:vue_mcp@postgres:5432/vue_mcp
POSTGRES_USER=vue_mcp
POSTGRES_PASSWORD=vue_mcp
POSTGRES_DB=vue_mcp

# Paths (inside ingestion container)
VUE_DOCS_PATH=/app/data/vue-docs/src
DATA_PATH=/app/data

# Server
SERVER_TRANSPORT=streamable-http
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
MASK_ERROR_DETAILS=true

# Ingestion schedule
INGESTION_INTERVAL_HOURS=24

# Traefik TLS
DOMAIN=mcp.vue-mcp.org
ACME_EMAIL=you@example.com
TLS_CERTRESOLVER=letsencrypt

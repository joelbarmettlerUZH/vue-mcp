# External APIs (required)
JINA_API_KEY=
GEMINI_API_KEY=

# PostgreSQL
POSTGRES_PASSWORD=change-me-to-a-strong-random-password
DATABASE_URL=postgresql+psycopg://vue_mcp:change-me@postgres:5432/vue_mcp

# Qdrant (internal network, no auth)
QDRANT_URL=http://qdrant:6333

# Server
SERVER_TRANSPORT=streamable-http
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
MASK_ERROR_DETAILS=true

# Ingestion schedule
INGESTION_INTERVAL_HOURS=24

# Traefik TLS (required)
DOMAIN=mcp.vue-mcp.org
ACME_EMAIL=you@example.com
TLS_CERTRESOLVER=letsencrypt
